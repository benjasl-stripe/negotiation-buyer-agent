# Do NOT put seller property-service secrets here (those live in property-service/.env.deploy).

# --- LLM via ai-chat-proxy Lambda (deploy ai-chat-proxy/ first — no local LLM key)
LAMBDA_ENDPOINT=https://3ik2p1nj9a.execute-api.us-west-2.amazonaws.com
WORKSHOP_SECRET=sessions
OPENAI_MODEL=gpt-4o-mini

# --- LLM URL
AGENT_PORT=3000
SESSION_SECRET=sessions

# --- Seller agent (AWS HTTP API — negotiation only)
SELLER_SERVICE_URL=https://xaawagr36f.execute-api.us-west-2.amazonaws.com
SELLER_SERVICE_KEY=1234


# --- Buyer Stripe wallet (BUYER account — different from property-service seller account)
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_API_VERSION=2026-04-22.preview

# Cross-account workshop use test_helper.
MPP_SPT_MINT_MODE=test_helper

# --- Negotiation judge (auto-scores when a run ends)
JUDGE_SERVICE_URL=https://825f3d2udf.execute-api.us-west-2.amazonaws.com
JUDGE_SERVICE_KEY=sessions
JUDGE_WORKSHOP_SECRET = sessions
