# Buyer agent — repo root `.env` (copy relevant lines into `.env`)
# Do NOT put seller property-service secrets here (those live in property-service/.env.deploy).

# --- OpenAI via ai-chat-proxy Lambda (deploy ai-chat-proxy/ first — no local OpenAI key)
LAMBDA_ENDPOINT=https://3ik2p1nj9a.execute-api.us-west-2.amazonaws.com
WORKSHOP_SECRET=sessions
OPENAI_MODEL=gpt-4o-mini

# --- Or call OpenAI directly (omit LAMBDA_ENDPOINT)
# OPENAI_API_KEY=sk-proj-...

AGENT_PORT=3000
SESSION_SECRET=sessions

# --- Seller agent (AWS HTTP API — negotiation only)
SELLER_SERVICE_URL=https://xaawagr36f.execute-api.us-west-2.amazonaws.com
# Same secret as Seller-agent stack SellerServiceKey parameter (if you enabled auth)
# SELLER_SERVICE_KEY=

# --- Buyer Stripe wallet (BUYER account — different from property-service seller account)
STRIPE_SECRET_KEY=sk_test_BUYER_...
STRIPE_PUBLISHABLE_KEY=pk_test_BUYER_...
STRIPE_API_VERSION=2026-04-22.preview

# Seller network profile id (public reference — NOT the buyer's profile)
STRIPE_PROFILE_ID=profile_test_61UpRd5aUNA6FVOF8A6UpRd46bE926oQ5kIpS7URcRc8

# Cross-account workshop (buyer Stripe ≠ seller property-service): use test_helper.
# Use issued only when buyer and seller share the same Stripe account / profile.
MPP_SPT_MINT_MODE=test_helper

# Optional wallet ledger demo
# WALLET_SPT_MINT_COST_CENTS=0
# MPP_SPT_DEFAULT_MAX_AMOUNT_CENTS=500000
# MPP_SPT_TTL_SECONDS=3600

# --- Negotiation judge (auto-scores when a run ends)
# JUDGE_SERVICE_URL=http://127.0.0.1:8791
# Or deployed negotiation-judge-service HttpApiUrl
# JUDGE_SERVICE_KEY=   # optional; match judge service JUDGE_SERVICE_KEY
# Event identifier for this hackathon cohort (results are bucketed by event_id)
# HACKATHON_EVENT_ID=nyc-summer-2026

# Property dossier tools: URLs are in agent/data/tools.manifest.json
# (already pointed at https://u8dawxdoyh.execute-api.us-west-2.amazonaws.com)
